---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteConfig } from '../site.config';

const { profile, socials, skills, projects } = siteConfig;
---

<BaseLayout>
  {/* ===== 背景光晕 ===== */}
  <div class="bg-glow" aria-hidden="true">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="glow glow-3"></div>
  </div>

  {/* ===== Hero 区域 — 双栏布局 ===== */}
  <section class="hero">
    <div class="hero-inner container">
      {/* 左侧：文字 */}
      <div class="hero-text">
        <div class="hero-badge animate-in">
          <span class="badge-dot"></span>
          个人主页
        </div>

        <h1 class="hero-title animate-in animate-in-delay-1">
          {profile.displayName}
        </h1>

        <p class="hero-subtitle animate-in animate-in-delay-2">
          {profile.englishName}
        </p>

        <p class="hero-bio animate-in animate-in-delay-3">
          {profile.bio}
        </p>

        <p class="hero-motto animate-in animate-in-delay-3">
          「{profile.motto}」
        </p>

        {/* 技能标签 */}
        <div class="hero-tags animate-in animate-in-delay-4">
          {skills.map((skill) => (
            <span class="hero-tag">{skill}</span>
          ))}
        </div>

        {/* CTA 按钮 */}
        <div class="hero-actions animate-in animate-in-delay-5">
          <a href={socials.find(s => s.name === 'Blog')?.url || '#'} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            博客
          </a>
          <a href="/about" class="btn btn-outline">
            关于我
          </a>
        </div>

        {/* 社交链接 */}
        <div class="hero-socials animate-in animate-in-delay-5">
          {socials.filter(s => s.name !== 'Blog').map((s) => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-link" title={s.name}>
              {s.name}
            </a>
          ))}
        </div>
      </div>

      {/* 右侧：头像面板 */}
      <div class="hero-panel animate-in animate-in-delay-2">
        <div class="panel-frost">
          <img
            src={profile.avatar}
            alt={profile.displayName}
            class="panel-avatar"
            loading="eager"
          />
        </div>
        <div class="panel-info">
          <div class="panel-info-inner">
            <div>
              <p class="panel-label">LOCATION</p>
              <p class="panel-value">{profile.location}</p>
            </div>
            <div>
              <p class="panel-label">SCHOOL</p>
              <p class="panel-value">{profile.school}</p>
            </div>
            <div>
              <p class="panel-label">BIRTHDAY</p>
              <p class="panel-value">{profile.birthday.replace('-', '年').replace('-', '月') + '日'}</p>
              <p class="panel-countdown" id="birthday-countdown" data-birthday={profile.birthday}></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 分隔线 ===== */}
  <div class="divider-section">
    <div class="container">
      <div class="divider">
        <span class="divider-label">项目</span>
      </div>
    </div>
  </div>

  {/* ===== 项目展示 ===== */}
  <section class="section">
    <div class="container">
      <p class="section-desc">
        我参与和维护的开源项目，偏工具向和实用主义。
      </p>
      <div class="projects-grid">
        {projects.map((project, i) => (
          <ProjectCard {...project} delay={i + 1} />
        ))}
      </div>
    </div>
  </section>

  {/* 生日倒计时脚本 */}
  <script is:inline>
    (function() {
      var el = document.getElementById('birthday-countdown');
      if (!el) return;
      var birthday = el.getAttribute('data-birthday');
      if (!birthday) return;
      var parts = birthday.split('-');
      var month = parseInt(parts[1], 10);
      var day = parseInt(parts[2], 10);

      function update() {
        var now = new Date();
        var year = now.getFullYear();
        var next = new Date(year, month - 1, day);
        if (next < now) next = new Date(year + 1, month - 1, day);
        var diff = Math.ceil((next - now) / (1000 * 60 * 60 * 24));
        if (diff === 0) {
          el.textContent = '🎂 今天是我生日！';
        } else {
          el.textContent = '距生日还有 ' + diff + ' 天';
        }
      }

      update();
      setInterval(update, 60000);
    })();
  </script>
</BaseLayout>

<style>
  /* ===== 背景光晕 ===== */
  .bg-glow {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.25;
    background: oklch(0.70 0.09 var(--hue));
  }

  :root.dark .glow {
    opacity: 0.08;
  }

  .glow-1 {
    left: -10%;
    top: 5%;
    width: 70%;
    height: 14rem;
  }

  .glow-2 {
    right: -5%;
    top: 30%;
    width: 12rem;
    height: 45%;
  }

  .glow-3 {
    left: -5%;
    top: 55%;
    width: 60%;
    height: 16rem;
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    z-index: 1;
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr minmax(0, max-content);
    gap: var(--space-3xl);
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  /* 左侧文字 */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--line-divider);
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-color-50);
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    margin-top: var(--space-lg);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--text-color);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 2.75rem;
    }
  }

  .hero-subtitle {
    margin-top: var(--space-xs);
    font-size: var(--text-lg);
    color: var(--text-color-50);
    font-weight: 400;
  }

  .hero-bio {
    margin-top: var(--space-md);
    font-size: var(--text-md);
    color: var(--text-color-75);
    line-height: 1.7;
  }

  .hero-motto {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--text-color-25);
    font-style: italic;
  }

  .hero-tags {
    margin-top: var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px var(--space-sm);
    font-size: var(--text-xs);
    color: var(--btn-content);
    background: var(--btn-regular-bg);
    border: 1px solid var(--line-divider);
    border-radius: var(--radius-sm);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .hero-tag:hover {
    background: var(--btn-regular-bg-hover);
    color: var(--primary);
    border-color: var(--primary);
  }

  .hero-actions {
    margin-top: var(--space-xl);
    display: flex;
    gap: var(--space-sm);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: 999px;
    transition: all var(--duration-fast) var(--ease-out);
    text-decoration: none;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--text-color);
    color: var(--page-bg);
    border: 1px solid var(--text-color);
  }

  .btn-primary:hover {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }

  .btn-outline {
    background: transparent;
    color: var(--text-color);
    border: 1px solid var(--line-color);
  }

  .btn-outline:hover {
    border-color: var(--text-color-50);
    background: var(--btn-regular-bg);
  }

  .hero-socials {
    margin-top: var(--space-lg);
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .social-link {
    font-size: var(--text-sm);
    color: var(--text-color-25);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .social-link::after {
    content: '→';
    margin-left: 2px;
    opacity: 0;
    transform: translateX(-4px);
    display: inline-block;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .social-link:hover {
    color: var(--primary);
  }

  .social-link:hover::after {
    opacity: 1;
    transform: translateX(0);
  }

  /* 右侧头像面板 */
  .hero-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    width: fit-content;
  }

  .panel-frost {
    position: relative;
    overflow: visible;
    border-radius: 2rem;
    border: 1px dashed var(--line-color);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    padding: var(--space-lg);
    box-shadow: 0 30px 90px -55px oklch(0.25 0.02 var(--hue) / 0.3);
    transition: all var(--duration-normal) var(--ease-out);
    max-width: 320px;
  }

  .panel-frost:hover {
    box-shadow: 0 30px 90px -55px oklch(0.70 0.09 var(--hue) / 0.2);
  }

  .panel-avatar {
    width: 100%;
    max-height: 28rem;
    object-fit: contain;
    border-radius: var(--radius-lg);
    filter: drop-shadow(0 22px 30px oklch(0.25 0.02 var(--hue) / 0.14));
  }

  :root.dark .panel-avatar {
    filter: drop-shadow(0 24px 30px oklch(0 0 0 / 0.42));
  }

  .panel-info {
    border-radius: 1.8rem;
    border: 1px dashed var(--line-color);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    padding: var(--space-md) var(--space-lg);
    transition: all var(--duration-normal) var(--ease-out);
    max-width: 320px;
  }

  .panel-info-inner {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    justify-content: center;
  }

  .panel-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-color-25);
    margin-bottom: 2px;
  }

  .panel-value {
    font-size: var(--text-sm);
    color: var(--text-color-75);
    font-weight: 500;
  }

  .panel-countdown {
    font-size: var(--text-xs);
    color: var(--primary);
    font-weight: 500;
    margin-top: 2px;
  }

  /* ===== 分隔线 ===== */
  .divider-section {
    padding: var(--space-2xl) 0;
  }

  .divider {
    position: relative;
    width: 100%;
    height: 1px;
    background: var(--line-divider);
  }

  .divider::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent, var(--line-color), transparent);
  }

  .divider-label {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: var(--page-bg);
    padding: var(--space-sm) var(--space-lg);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-color-50);
    border: 1px solid var(--line-divider);
    border-radius: 999px;
    white-space: nowrap;
  }

  /* ===== 项目区 ===== */
  .section-desc {
    font-size: var(--text-md);
    color: var(--text-color-50);
    margin-bottom: var(--space-2xl);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
