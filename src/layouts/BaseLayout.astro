---
import { siteConfig } from '../site.config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
} = Astro.props;
---
<!DOCTYPE html>
<html lang={siteConfig.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  {/* 主题初始化 — 防止闪烁 */}
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = stored || (prefersDark ? 'dark' : 'light');
      if (theme === 'dark') document.documentElement.classList.add('dark');
    })();
  </script>

  {/* MiSans 字体 */}
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link
    href="https://cdn.jsdelivr.net/npm/misans@4.0/lib/Normal/MiSans-Regular.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/misans@4.0/lib/Normal/MiSans-Semibold.min.css"
    rel="stylesheet"
  />

  {/* Favicon */}
  <link rel="icon" href="/favicon.ico" sizes="64x64" />
</head>
<body>
  {/* Liquid Glass 功能层: 导航栏 */}
  <nav class="nav glass-card glass-highlight">
    <div class="nav-inner container">
      <a href="/" class="nav-brand">
        <img src="/favicon.ico" alt="Logo" class="nav-brand-icon" />
        <span class="nav-brand-text">{siteConfig.profile.displayName}</span>
      </a>
      <div class="nav-right">
        <div class="nav-links">
          {siteConfig.nav.map((item) => (
            <a href={item.href} class="nav-link">{item.label}</a>
          ))}
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
          {/* 太阳图标 (浅色模式显示) */}
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          {/* 月亮图标 (深色模式显示) */}
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  {/* 内容层 */}
  <main>
    <slot />
  </main>

  {/* 页脚 */}
  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-text">
        {siteConfig.footer.copyright}
        <a href={siteConfig.footer.authorUrl} target="_blank" rel="noopener noreferrer">{siteConfig.footer.authorName}</a>
      </span>
      <span class="footer-sep">·</span>
      <span class="footer-text">
        Powered by <a href={siteConfig.footer.poweredByUrl} target="_blank" rel="noopener noreferrer">Astro</a> · <a href={siteConfig.footer.themeUrl}>xcTheme</a>
      </span>
      <span class="footer-sep">·</span>
      <span class="footer-text">
        <a href={siteConfig.footer.icpUrl} target="_blank" rel="noopener noreferrer">{siteConfig.footer.icp}</a>
      </span>
    </div>
  </footer>

  {/* 主题切换逻辑 */}
  <script is:inline>
    (function() {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;

      function getEffectiveTheme() {
        var stored = localStorage.getItem('theme');
        if (stored) return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function applyTheme(theme) {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }

      btn.addEventListener('click', function() {
        var current = getEffectiveTheme();
        var next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme(next);
      });

      // 监听系统主题变化 (当用户未手动选择时自动跟随)
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        if (!localStorage.getItem('theme')) {
          applyTheme(e.matches ? 'dark' : 'light');
        }
      });
    })();
  </script>
</body>
</html>

<style>
  /* ===== 导航栏 — Liquid Glass 悬浮功能层 ===== */
  .nav {
    position: fixed;
    top: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - var(--space-xl) * 2);
    max-width: min(90vw, 1200px);
    z-index: 100;
    padding: var(--space-sm) var(--space-md);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-color);
    text-decoration: none;
  }

  .nav-brand:hover {
    color: var(--primary);
  }

  .nav-brand-icon {
    width: 22px;
    height: 22px;
    border-radius: 4px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-links {
    display: flex;
    gap: var(--space-xs);
  }

  .nav-link {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-base);
    color: var(--text-color-50);
    border-radius: 999px;
    transition: all var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text-color);
    background: var(--btn-regular-bg);
  }

  /* ===== 页脚 ===== */
  .footer {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--line-divider);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    text-align: center;
  }

  .footer-text {
    font-size: var(--text-sm);
    color: var(--text-color-25);
  }

  .footer-text a {
    color: var(--text-color-50);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-text a:hover {
    color: var(--primary);
  }

  .footer-sep {
    color: var(--text-color-25);
  }

  /* 为 fixed 导航栏留出空间 */
  main {
    padding-top: calc(60px + var(--space-xl) * 2);
  }
</style>
